@model SGA.Models.HazardousWaste

@{
    ViewData["Title"] = "Editar Residuo Peligroso";
    var cretibList = ViewBag.CretibList as List<SGA.Models.Cretib>;
    var selectedCretib = ViewBag.SelectedCretib as List<int> ?? new List<int>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-warning">
                    <h3 class="mb-0"><i class="bi bi-pencil"></i> Editar Residuo Peligroso</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="HazardousWasteId" />
                        <input type="hidden" asp-for="CreatedDate" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <!-- Clave -->
                        <div class="mb-3">
                            <label asp-for="WasteKey" class="form-label fw-bold">Clave *</label>
                            <input asp-for="WasteKey" class="form-control" placeholder="Ej: RP-001" required />
                            <span asp-validation-for="WasteKey" class="text-danger"></span>
                        </div>

                        <!-- Nombre -->
                        <div class="mb-3">
                            <label asp-for="WasteName" class="form-label fw-bold">Nombre del Residuo *</label>
                            <input asp-for="WasteName" class="form-control" placeholder="Ej: Aceite usado contaminado" required />
                            <span asp-validation-for="WasteName" class="text-danger"></span>
                        </div>

                        <!-- Descripción -->
                        <div class="mb-3">
                            <label asp-for="WasteDescription" class="form-label fw-bold">Descripción</label>
                            <textarea asp-for="WasteDescription" class="form-control" rows="3" placeholder="Descripción detallada del residuo..."></textarea>
                            <span asp-validation-for="WasteDescription" class="text-danger"></span>
                        </div>

                        <!-- Códigos CRETIB -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Códigos CRETIB</label>
                            <div class="card">
                                <div class="card-body">
                                    <p class="text-muted small mb-3">Selecciona los códigos que apliquen para este residuo:</p>
                                    <div class="row">
                                        @if (cretibList != null)
                                        {
                                            @foreach (var cretib in cretibList)
                                            {
                                                <div class="col-md-6 mb-2">
                                                    <div class="form-check">
                                                        <input class="form-check-input"
                                                               type="checkbox"
                                                               name="selectedCretib"
                                                               value="@cretib.CretibId"
                                                               id="cretib_@cretib.CretibId"
                                                               @(selectedCretib.Contains(cretib.CretibId) ? "checked" : "")>
                                                        <label class="form-check-label" for="cretib_@cretib.CretibId">
                                                            <span class="badge bg-danger">@cretib.CretibKey</span>
                                                            <strong>@cretib.CretibName</strong>
                                                            @if (!string.IsNullOrEmpty(cretib.CretibDescription))
                                                            {
                                                                <br />
                                                                <small class="text-muted">@cretib.CretibDescription</small>
                                                            }
                                                        </label>
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="col-12">
                                                <p class="text-danger">No hay códigos CRETIB disponibles.</p>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Estado -->
                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label fw-bold">
                                    Activo
                                </label>
                            </div>
                        </div>

                        <!-- Información de fechas -->
                        <div class="mb-3">
                            <small class="text-muted">
                                <i class="bi bi-calendar"></i> Creado: @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                                @if (Model.ModifiedDate.HasValue)
                                {
                                    <br />
                                    <text><i class="bi bi-pencil"></i> Última modificación: </text>@Model.ModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")
                                }
                            </small>
                        </div>

                        <!-- Botones -->
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
