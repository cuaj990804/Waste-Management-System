@model SGA.Models.HazardousArea

@{
    ViewData["Title"] = "Detalles";
}

<h1>Detalles</h1>

<div>
    <h4>Área de residuos peligrosos</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Clave</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.AreaKey)</dd>
        <dt class="col-sm-2">Área en GDI</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.AreaName)</dd>
        <dt class="col-sm-2">Descripción</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.AreaDescription)</dd>
        <dt class="col-sm-2">Activo</dt>
        <dd class="col-sm-10">@(Model.IsActive ? "Sí" : "No")</dd>
        <dt class="col-sm-2">Fecha de creación</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.CreatedDate)</dd>
        <dt class="col-sm-2">Fecha de modificación</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.ModifiedDate)</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.HazardousAreaId">Editar</a> |
    <a asp-action="Index">Back to List</a>
</div>
