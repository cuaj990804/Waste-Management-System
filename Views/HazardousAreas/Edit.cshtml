@model SGA.Models.HazardousArea

@{
    ViewData["Title"] = "Editar área";
}

<h1>Editar</h1>

<h4>Área de residuos peligrosos</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="HazardousAreaId" />
            <div class="form-group">
                <label asp-for="AreaKey" class="control-label">Clave</label>
                <input asp-for="AreaKey" class="form-control" />
                <span asp-validation-for="AreaKey" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AreaName" class="control-label">Área en GDI</label>
                <input asp-for="AreaName" class="form-control" />
                <span asp-validation-for="AreaName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AreaDescription" class="control-label">Descripción</label>
                <input asp-for="AreaDescription" class="form-control" />
                <span asp-validation-for="AreaDescription" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsActive" /> @Html.DisplayNameFor(model => model.IsActive)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Guardar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
