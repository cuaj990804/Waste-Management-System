@model SGA.Models.HazardousWasteManifest

@{
    Layout = null;
}

<div class="row">
    <div class="col-md-12">
        <form asp-action="Edit" asp-route-id="@Model.Id" id="editForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Folio" class="form-label">Folio</label>
                        <input asp-for="Folio" class="form-control" />
                        <span asp-validation-for="Folio" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="WasteName" class="control-label">Nombre del residuo</label>
                        <input asp-for="WasteName" class="form-control" required />
                        <span asp-validation-for="WasteName" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Quantity" class="control-label">Cantidad</label>
                        <input asp-for="Quantity" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="WeightKg" class="control-label">Peso (KG)</label>
                        <input asp-for="WeightKg" class="form-control" type="number" step="0.0001" />
                        <span asp-validation-for="WeightKg" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <label class="form-label">Características CRETIB</label>
                    <div class="form-group">
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" name="Corrosive" id="Corrosive" value="true" @(Model.Corrosive == true ? "checked" : "")>
                            <label class="form-check-label" for="Corrosive">
                                <strong>C</strong> - Corrosivo
                            </label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" name="Reactive" id="Reactive" value="true" @(Model.Reactive == true ? "checked" : "")>
                            <label class="form-check-label" for="Reactive">
                                <strong>R</strong> - Reactivo
                            </label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" name="Explosive" id="Explosive" value="true" @(Model.Explosive == true ? "checked" : "")>
                            <label class="form-check-label" for="Explosive">
                                <strong>E</strong> - Explosivo
                            </label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" name="Toxic" id="Toxic" value="true" @(Model.Toxic == true ? "checked" : "")>
                            <label class="form-check-label" for="Toxic">
                                <strong>T</strong> - Tóxico
                            </label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" name="Flammable" id="Flammable" value="true" @(Model.Flammable == true ? "checked" : "")>
                            <label class="form-check-label" for="Flammable">
                                <strong>I</strong> - Inflamable
                            </label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" name="Biological" id="Biological" value="true" @(Model.Biological == true ? "checked" : "")>
                            <label class="form-check-label" for="Biological">
                                <strong>B</strong> - Biológico-Infeccioso
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="GenerationArea" class="control-label">Área de generación</label>

                        <select asp-for="GenerationArea" class="form-control">
                            <option value="">-- Seleccione un área --</option>
                            @foreach (var area in ViewBag.HazardousAreas as List<string>)
                            {
                                <option value="@area">@area</option>
                            }
                        </select>

                        <span asp-validation-for="GenerationArea" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="GenerationManagerName" class="control-label">Responsable del área generadora</label>
                        <input asp-for="GenerationManagerName" class="form-control" />
                        <span asp-validation-for="GenerationManagerName" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="WarehouseEntryDate" class="control-label">Fecha de ingreso al almacén</label>
                        <input name="WarehouseEntryDate"
                               id="WarehouseEntryDate"
                               class="form-control"
                               type="date"
                               value="@(Model.WarehouseEntryDate.HasValue ? Model.WarehouseEntryDate.Value.ToString("yyyy-MM-dd") : "")" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="WarehouseExitDate" class="control-label">Fecha de salida del almacén</label>
                        <input name="WarehouseExitDate"
                               id="WarehouseExitDate"
                               class="form-control"
                               type="date"
                               value="@(Model.WarehouseExitDate.HasValue ? Model.WarehouseExitDate.Value.ToString("yyyy-MM-dd") : "")" />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="ManifestNumber" class="control-label">Número de manifiesto</label>
                        <input asp-for="ManifestNumber" class="form-control" />
                        <span asp-validation-for="ManifestNumber" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="ManifestDeliveredBy" class="control-label">Entregado por</label>
                        <input asp-for="ManifestDeliveredBy" class="form-control" />
                        <span asp-validation-for="ManifestDeliveredBy" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="ManifestReceivedBy" class="control-label">Recibido por</label>
                        <input asp-for="ManifestReceivedBy" class="form-control" />
                        <span asp-validation-for="ManifestReceivedBy" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="CollectionTransportName" class="control-label">Nombre del transportista</label>
                        <input asp-for="CollectionTransportName" class="form-control" />
                        <span asp-validation-for="CollectionTransportName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="CollectionTransportAuthNumber" class="control-label">Núm. de autorización del transportista</label>
                        <input asp-for="CollectionTransportAuthNumber" class="form-control" />
                        <span asp-validation-for="CollectionTransportAuthNumber" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="FinalDisposalName" class="control-label">Nombre empresa de disposición final</label>
                        <input asp-for="FinalDisposalName" class="form-control" />
                        <span asp-validation-for="FinalDisposalName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="FinalDisposalAuthNumber" class="control-label">Núm. de autorización disposición final</label>
                        <input asp-for="FinalDisposalAuthNumber" class="form-control" />
                        <span asp-validation-for="FinalDisposalAuthNumber" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="ManifestSealed" class="control-label">Manifiesto sellado</label>
                        <select name="ManifestSealed" id="ManifestSealed" class="form-control">
                            <option value="">Seleccione una opción</option>
                           
                            <option value="true" selected="@(Model.ManifestSealed == true)">Sí</option>
                            <option value="false" selected="@(Model.ManifestSealed == false)">No</option>
                
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Comments" class="control-label">Comentarios</label>
                        <textarea asp-for="Comments" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Comments" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
